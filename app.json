{
  "expo": {
    "name": "PyXode",
    "slug": "pyxode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pyxode",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sensei123.pyxode"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@clerk/expo",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#212121",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-web-browser",
      "expo-sqlite",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec37ce37-4306-4f00-b30e-cd6a94d6e746"
      },
      "EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID": "1033491632620-0lcdopc7r6pdp8a9ohd4t9nhuu078rto.apps.googleusercontent.com",
      "EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID": "1033491632620-hd0hs4520vo3ok5iansno5fdocf22i3v.apps.googleusercontent.com"
    }
  }
}